# -------------------------------------------------------
# Redash — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# -------------------------------------------------------

# --- Configurações gerais ---
PYTHONUNBUFFERED=0
REDASH_LOG_LEVEL=INFO
REDASH_GUNICORN_TIMEOUT=60
REDASH_ENFORCE_CSRF=true

# --- Secrets (gere com: openssl rand -hex 32) ---
REDASH_COOKIE_SECRET=TROQUE_POR_STRING_ALEATORIA_DE_32_CHARS
REDASH_SECRET_KEY=TROQUE_POR_STRING_ALEATORIA_DE_32_CHARS

# --- Redis ---
REDASH_REDIS_URL=redis://redis:6379/0

# --- PostgreSQL ---
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
REDASH_DATABASE_URL=postgresql://postgres:TROQUE_POR_SENHA_FORTE@postgres/postgres

# --- Google OAuth (deixe em branco para desabilitar login via Google) ---
# Pré-requisito: crie um OAuth 2.0 Client ID em console.cloud.google.com
# Authorized redirect URI: http://<SEU_IP_OU_DOMINIO>/oauth/google
REDASH_GOOGLE_CLIENT_ID=
REDASH_GOOGLE_CLIENT_SECRET=
